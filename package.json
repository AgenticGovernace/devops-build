{
  "name": "devops-build",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "install:dev": "npm install",
    "install:prod": "npm install --omit=dev",
    "install:ci": "npm ci",
    "install:ci:prod": "npm ci --omit=dev",
    "start": "npx vite preview",
    "dev": "npx vite",
    "serve": "npx vite preview --host",
    "build": "npx vite build",
    "build:prod": "npx vite build --mode production",
    "preview": "npx vite preview",
    "clean": "rm -rf dist node_modules/.vite",
    "clean:all": "rm -rf dist node_modules package-lock.json",
    "rebuild": "npm run clean && npm run build",
    "typecheck": "npx tsc --noEmit",
    "test": "npx vitest",
    "test:run": "npx vitest run",
    "test:watch": "npx vitest watch",
    "test:coverage": "npx vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:all": "npm run test:run && npm run test:e2e",
    "lint": "npx eslint . --ext .ts,.tsx",
    "lint:fix": "npx eslint . --ext .ts,.tsx --fix",
    "format": "npx prettier --write \"**/*.{ts,tsx,json,css,md}\"",
    "format:check": "npx prettier --check \"**/*.{ts,tsx,json,css,md}\"",
    "validate": "npm run typecheck && npm run lint && npm run test:run",
    "prepare": "husky",
    "preversion": "npm run validate",
    "version": "npm run format && git add -A",
    "postversion": "git push && git push --tags"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "npx eslint --fix"
    ],
    "**/*.{ts,tsx,json,css,md}": [
      "npx prettier --write"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.7.0",
    "dompurify": "^3.3.3",
    "jszip": "^3.10.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "vega": "^6.2.0",
    "vega-embed": "^6.29.0",
    "vega-lite": "^6.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.45.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.14.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsdoc": "^61.5.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
